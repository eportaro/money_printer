PRICE_SOURCE=coinbase
COINBASE_PRODUCT_ID=BTC-USD
BINANCE_SYMBOL=BTCUSDT
WINDOW_SECONDS=900
POLYMARKET_INTERVAL=15m

DB_BACKEND=sqlserver
SQLSERVER_DATABASE=PolymarketBot
# Use the docker service name "sqlserver" as host. Set PWD to your own SA password.
SQLSERVER_CONNECTION=DRIVER={ODBC Driver 18 for SQL Server};SERVER=sqlserver,1433;DATABASE=PolymarketBot;UID=sa;PWD=CHANGE_ME_STRONG_PASSWORD;Encrypt=no;TrustServerCertificate=yes;

PERSIST_FROM_SERVER=false
COLLECTOR_MODE=scheduled_buckets
ADAPTIVE_CAPTURE_ENABLED=false
REQUIRE_EXACT_BASELINE_FOR_ACTION=true
ALLOW_PRICE_FEED_BASELINE_FOR_ACTION=true
REQUIRE_EXACT_CLOSE_FOR_RESOLUTION=true
RESOLUTION_CHECK_INTERVAL_SECONDS=5
PROVISIONAL_CLOSE_AFTER_SECONDS=20

ACTIVE_MODEL=market-aware-v1
MODEL_STAGE=production
FEATURE_SET_VERSION=market-features-v1
STRATEGY_VERSION=edge-v1
EDGE_THRESHOLD=0.05
STAKE_SIZE=1
COLLECTOR_STAKE_SIZE=1
MIN_ASK_SIZE=10
MSSQL_MEMORY_LIMIT_MB=3072
TRAINING_N_JOBS=1

# Lower CPU footprint on the VPS: skip the per-resolution backtest subprocess.
STRATEGY_LAB_AUTO_REFRESH=false

APP_HOST=0.0.0.0
APP_PORT=5000
