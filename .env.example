# App
FLASK_ENV=production
APP_HOST=0.0.0.0
APP_PORT=5000
ACTIVE_MODEL=market-aware-v1

# Supabase
# Use Project Settings > API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional direct Postgres URL for manual scripts only.
SUPABASE_DB_URL=
DATABASE_URL=

# Market discovery
# Optional: set one of these when you know the active Polymarket slug.
POLYMARKET_EVENT_SLUG=
POLYMARKET_MARKET_SLUG=
POLYMARKET_SEARCH_QUERY=BTC arriba abajo 5 m

# Snapshot collector
COLLECTOR_INTERVAL_SECONDS=5
COLLECTOR_STAKE_SIZE=10
EDGE_THRESHOLD=0.07

# Binance
BINANCE_SYMBOL=BTCUSDT
