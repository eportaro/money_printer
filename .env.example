PRICE_SOURCE=coinbase
COINBASE_PRODUCT_ID=BTC-USD
BINANCE_SYMBOL=BTCUSDT
WINDOW_SECONDS=900
POLYMARKET_INTERVAL=15m

# Local SQL Server (running the bot WITHOUT docker). For docker use .env.docker.
SQLSERVER_CONNECTION=DRIVER={ODBC Driver 18 for SQL Server};SERVER=localhost;DATABASE=PolymarketBot;Trusted_Connection=yes;Encrypt=no;TrustServerCertificate=yes;
# Password for the SQL Server docker container (docker-compose reads this; the PWD in
# SQLSERVER_CONNECTION inside .env.docker must match it).
MSSQL_SA_PASSWORD=CHANGE_ME_STRONG_PASSWORD

ADAPTIVE_CAPTURE_ENABLED=false
EDGE_THRESHOLD=0.05
# Live signal gating (see collector.py): entry-price cap, alignment with the model
# call, liquidity floor, and a late-round cutoff where signals are never emitted.
SIGNAL_MAX_ENTRY_PRICE=1.0
SIGNAL_REQUIRE_ALIGNED=false
SIGNAL_EXCLUDE_BELOW_SECONDS=0
MIN_ASK_SIZE=0
REQUIRE_EXACT_BASELINE_FOR_ACTION=true
REQUIRE_EXACT_CLOSE_FOR_RESOLUTION=true
RESOLUTION_CHECK_INTERVAL_SECONDS=5
PROVISIONAL_CLOSE_AFTER_SECONDS=20
ACTIVE_MODEL=market-aware-v1
PERFORMANCE_CACHE_SECONDS=60
